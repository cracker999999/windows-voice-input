<Window x:Class="VoiceInput.UI.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="280"
        Height="56"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        ShowActivated="False"
        Title="Overlay">
    <Window.Resources>
        <Storyboard x:Key="EntryStoryboard">
            <DoubleAnimation Storyboard.TargetName="RootScaleTransform"
                             Storyboard.TargetProperty="ScaleX"
                             From="0.6"
                             To="1.0"
                             Duration="0:0:0.35">
                <DoubleAnimation.EasingFunction>
                    <ElasticEase EasingMode="EaseOut" Oscillations="1" Springiness="4" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="RootScaleTransform"
                             Storyboard.TargetProperty="ScaleY"
                             From="0.6"
                             To="1.0"
                             Duration="0:0:0.35">
                <DoubleAnimation.EasingFunction>
                    <ElasticEase EasingMode="EaseOut" Oscillations="1" Springiness="4" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0"
                             To="1"
                             Duration="0:0:0.35" />
        </Storyboard>

        <Storyboard x:Key="ExitStoryboard">
            <DoubleAnimation Storyboard.TargetName="RootScaleTransform"
                             Storyboard.TargetProperty="ScaleX"
                             From="1.0"
                             To="0.8"
                             Duration="0:0:0.22">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="RootScaleTransform"
                             Storyboard.TargetProperty="ScaleY"
                             From="1.0"
                             To="0.8"
                             Duration="0:0:0.22">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="1"
                             To="0"
                             Duration="0:0:0.22">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Grid RenderTransformOrigin="0.5,0.5">
        <Grid.RenderTransform>
            <ScaleTransform x:Name="RootScaleTransform" ScaleX="1" ScaleY="1" />
        </Grid.RenderTransform>

        <Border x:Name="CapsuleBorder"
                Width="280"
                Height="56"
                Background="#DD1E1F22"
                CornerRadius="28"
                Padding="12,10,14,10"
                BorderBrush="#552E2F33"
                BorderThickness="1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Grid Width="44" Height="32" VerticalAlignment="Center" Margin="0,0,12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="8" />
                    </Grid.ColumnDefinitions>

                    <Rectangle x:Name="Bar1" Grid.Column="0" Width="6" Height="4" Fill="#FFF5F5F5" RadiusX="1" RadiusY="1" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Rectangle x:Name="Bar2" Grid.Column="1" Width="6" Height="4" Fill="#FFF5F5F5" RadiusX="1" RadiusY="1" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Rectangle x:Name="Bar3" Grid.Column="2" Width="6" Height="4" Fill="#FFF5F5F5" RadiusX="1" RadiusY="1" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Rectangle x:Name="Bar4" Grid.Column="3" Width="6" Height="4" Fill="#FFF5F5F5" RadiusX="1" RadiusY="1" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Rectangle x:Name="Bar5" Grid.Column="4" Width="6" Height="4" Fill="#FFF5F5F5" RadiusX="1" RadiusY="1" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Grid>

                <TextBlock x:Name="TranscriptText"
                           MinWidth="160"
                           MaxWidth="560"
                           VerticalAlignment="Center"
                           Foreground="#FFF5F5F5"
                           FontSize="14"
                           TextTrimming="CharacterEllipsis"
                           TextWrapping="NoWrap" />
            </StackPanel>
        </Border>
    </Grid>
</Window>


